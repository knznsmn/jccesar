.siteNav {
  --scroll-progress: 0;
  --reveal-x: 2.3rem;
  --reveal-y: 2.3rem;
  --menu-reveal-ease: cubic-bezier(0.2, 0.95, 0.28, 1);
  position: sticky;
  top: 0;
  z-index: 50;
  min-height: 3.8rem;
  display: grid;
  align-items: center;
  background: transparent;
}

.mobileDetails {
  display: block;
}

.mobileDetails > summary {
  list-style: none;
}

.mobileDetails > summary::-webkit-details-marker {
  display: none;
}

.mobileDetails > :not(summary) {
  display: block;
}

.menuToggle {
  display: inline-flex;
  position: fixed;
  top: clamp(0.55rem, 1.3vw, 0.9rem);
  left: clamp(0.8rem, 3.8vw, 1.7rem);
  z-index: 60;
  width: clamp(2.55rem, 3.6vw, 2.9rem);
  height: clamp(2.55rem, 3.6vw, 2.9rem);
  background: transparent;
  color: var(--foreground);
  cursor: pointer;
  align-items: center;
  justify-content: center;
  gap: 0.3rem;
  flex-direction: column;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
  transition: color 180ms ease, transform 200ms ease;
}

.menuToggle:hover,
.menuToggle:focus-visible {
  color: var(--focus);
}

.menuToggle:active {
  transform: scale(0.96);
}

.mobileDetails[open] .menuToggle {
  color: var(--background);
}

.menuToggleBar {
  width: 1.38rem;
  height: 2px;
  background: currentcolor;
  transition: transform 520ms cubic-bezier(0.22, 1.2, 0.25, 1), opacity 240ms ease;
}

.menuToggleOpen .menuToggleBar:nth-child(1) {
  transform: translateY(6px) rotate(45deg);
}

.menuToggleOpen .menuToggleBar:nth-child(2) {
  opacity: 0;
}

.menuToggleOpen .menuToggleBar:nth-child(3) {
  transform: translateY(-6px) rotate(-45deg);
}

.mobileMenu {
  position: fixed;
  inset: 0;
  z-index: 55;
  color: var(--background);
  background:
    radial-gradient(circle at 20% 18%, color-mix(in srgb, var(--background) 20%, transparent), transparent 34%),
    linear-gradient(160deg, color-mix(in srgb, var(--foreground) 92%, black), var(--foreground));
  pointer-events: none;
  clip-path: circle(0 at var(--reveal-x) var(--reveal-y));
  will-change: clip-path;
}

.mobileDetails[open] .mobileMenu {
  pointer-events: auto;
  animation: menuReveal 1300ms var(--menu-reveal-ease) forwards;
}

.mobileDetails:not([open]) .mobileMenu {
  pointer-events: none;
  animation: menuReveal 1300ms var(--menu-reveal-ease) reverse forwards;
}

@keyframes menuReveal {
  from {
    clip-path: circle(0 at var(--reveal-x) var(--reveal-y));
  }
  to {
    clip-path: circle(170vmax at var(--reveal-x) var(--reveal-y));
  }
}

.mobileMenuInner {
  width: 100%;
  min-height: 100dvh;
  padding: 5.2rem 4vw 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mobileMenuGroup {
  width: min(560px, 92vw);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
}

.mobileMenuLogoWrap {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 420ms cubic-bezier(0.22, 1, 0.36, 1) 140ms, transform 540ms cubic-bezier(0.2, 1.2, 0.3, 1) 140ms;
}

.mobileDetails[open] .mobileMenuLogoWrap {
  opacity: 1;
  transform: translateY(0);
}

.mobileMenuLogo {
  width: min(170px, 42vw);
  height: auto;
  filter: brightness(0) invert(1);
}

.mobileMenuLinks {
  list-style: none;
  width: 100%;
  display: grid;
  gap: 0.52rem;
}

.mobileMenuLinks li {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 340ms cubic-bezier(0.22, 1, 0.36, 1) var(--mobile-link-delay, 180ms), transform 500ms cubic-bezier(0.2, 1.2, 0.3, 1) var(--mobile-link-delay, 180ms);
}

.mobileDetails[open] .mobileMenuLinks li {
  opacity: 1;
  transform: translateY(0);
}

.mobileNavLink {
  position: relative;
  overflow: hidden;
  display: inline-flex;
  width: 100%;
  justify-content: space-between;
  align-items: center;
  padding: 0.82rem 0.9rem;
  color: var(--background);
  background: color-mix(in srgb, var(--background) 12%, transparent);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: 0.82rem;
  transition: background-color 180ms ease;
}

.mobileNavLink::after {
  content: ">";
  color: color-mix(in srgb, var(--background) 82%, transparent);
}

.mobileNavLink:hover,
.mobileNavLink:focus-visible {
  background: color-mix(in srgb, var(--background) 22%, transparent);
}

.mobileNavLinkActive {
  background: color-mix(in srgb, var(--background) 24%, transparent);
}

.mobileNavLinkActive::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--background);
  transform-origin: bottom center;
  transform: scaleY(var(--scroll-progress));
  transition: transform 160ms linear;
}

.mobileMenuTools {
  margin-top: 0.2rem;
}
